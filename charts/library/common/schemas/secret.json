{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/secret.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the Secret.",
          "type": "boolean",
          "default": true
        },
        "includeInChecksum": {
          "description": "Set to true to include this Secret in the checksum calculation for rolling updates.",
          "type": "boolean",
          "default": true
        },
        "includeChecksumInControllers": {
          "description": "Specify a list of controller identifiers for which to include this Secret in the checksum calculation for rolling updates.",
          "type": "array"
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "type": {
          "description": "Secret type.",
          "type": "string"
        },
        "stringData": {
          "description": "Secret stringData content. Helm templates are supported.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "stringData"
      ]
    }
  }
}
