{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/configmap.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the ConfigMap.",
          "type": "boolean",
          "default": true
        },
        "includeInChecksum": {
          "description": "Set to true to include this ConfigMap in the checksum calculation for rolling updates.",
          "type": "boolean",
          "default": true
        },
        "includeChecksumInControllers": {
          "description": "Specify a list of controller identifiers for which to include this ConfigMap in the checksum calculation for rolling updates.",
          "type": "array"
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "data": {
          "description": "ConfigMap data content. Helm templates are supported.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "binaryData": {
          "description": "ConfigMap binaryData content.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "data"
          ]
        },
        {
          "required": [
            "binaryData"
          ]
        }
      ]
    }
  }
}
