{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/rawResource.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the resource.",
          "type": "boolean",
          "default": true
        },
        "manifest": {
          "description": "The raw K8s resource manifest to be rendered. apiVersion and kind are required.",
          "type": "object",
          "properties": {
            "apiVersion": {
              "description": "apiVersion of the resource.",
              "type": "string"
            },
            "kind": {
              "description": "Kind of the resource.",
              "type": "string"
            },
            "metadata": {
              "type": "object",
              "properties": {
                "namespace": {
                  "description": "Namespace of the resource.",
                  "type": "string"
                },
                "labels": {
                  "$ref": "definitions.json#/$defs/labels"
                },
                "annotations": {
                  "$ref": "definitions.json#/$defs/annotations"
                }
              }
            }
          },
          "required": [
            "apiVersion",
            "kind"
          ],
          "additionalProperties": true
        }
      },
      "required": [
        "manifest"
      ]
    }
  }
}
