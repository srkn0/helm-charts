{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/controllers.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/instance.type.deployment"
            },
            {
              "$ref": "#/$defs/instance.type.statefulset"
            },
            {
              "$ref": "#/$defs/instance.type.daemonset"
            },
            {
              "$ref": "#/$defs/instance.type.cronjob"
            },
            {
              "$ref": "#/$defs/instance.type.job"
            }
          ]
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the controller.",
          "type": "boolean",
          "default": true
        },
        "type": {
          "description": "Controller type. Supported values: deployment, daemonset, statefulset, cronjob, job.",
          "type": "string",
          "enum": [
            "deployment",
            "statefulset",
            "daemonset",
            "cronjob",
            "job"
          ],
          "default": "deployment"
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "pod": {
          "description": "Pod-level options for this controller.",
          "$ref": "pod.json#/$defs/options"
        },
        "replicas": {
          "description": "Number of desired pods. When a HorizontalPodAutoscaler is configured, `replicas` is automatically suppressed on the controller and propagated to HPA `minReplicas` if not explicitly set.",
          "type": [
            "integer",
            "null"
          ],
          "default": 1
        },
        "revisionHistoryLimit": {
          "description": "ReplicaSet revision history limit.",
          "type": "integer"
        },
        "rollingUpdate": {
          "description": "Controller upgrade strategy options.",
          "type": "object"
        },
        "strategy": {
          "description": "Controller upgrade strategy. For Deployments: `Recreate` or `RollingUpdate`. For StatefulSets: `OnDelete` or `RollingUpdate`. DaemonSets, CronJobs and Jobs ignore this field.",
          "type": "string"
        },
        "applyDefaultContainerOptionsToInitContainers": {
          "description": "Apply defaultContainerOptions to initContainers.",
          "type": "boolean",
          "default": true
        },
        "defaultContainerOptionsStrategy": {
          "description": "Strategy for default container options.\noverwrite: use container-level options if set.\nmerge: merge container-level options with defaults.",
          "type": "string",
          "default": "overwrite",
          "enum": [
            "overwrite",
            "merge"
          ]
        },
        "defaultContainerOptions": {
          "description": "Default options for all (init)Containers. Each can be overridden on a container level.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "args": {
              "$ref": "containers.json#/$defs/args"
            },
            "command": {
              "$ref": "containers.json#/$defs/command"
            },
            "env": {
              "$ref": "containers.json#/$defs/env"
            },
            "envFrom": {
              "$ref": "containers.json#/$defs/envFrom"
            },
            "image": {
              "$ref": "containers.json#/$defs/image"
            },
            "resources": {
              "$ref": "k8s-api.json#/$defs/core.v1.ResourceRequirements"
            },
            "securityContext": {
              "$ref": "k8s-api.json#/$defs/core.v1.ContainerSecurityContext"
            }
          }
        },
        "initContainers": {
          "description": "InitContainers as dictionary items.",
          "type": "object",
          "additionalProperties": {
            "$ref": "containers.json#/$defs/container"
          }
        },
        "containers": {
          "description": "Containers as dictionary items.",
          "type": "object",
          "additionalProperties": {
            "$ref": "containers.json#/$defs/container"
          }
        },
        "serviceAccount": {
          "description": "ServiceAccount used by the controller. Only use one of `name` or `identifier`. When both are specified, `identifier` takes priority.",
          "type": "object",
          "properties": {
            "name": {
              "description": "Reference a serviceAccount by its name. Helm templates are supported.",
              "type": "string"
            },
            "identifier": {
              "description": "Reference a serviceAccount configured in this chart by its key.",
              "type": "string"
            }
          }
        },
        "podDisruptionBudget": {
          "description": "PodDisruptionBudget Policy for this controller.",
          "type": "object",
          "properties": {
            "minAvailable": {
              "type": [
                "integer",
                "string"
              ]
            },
            "maxUnavailable": {
              "type": [
                "integer",
                "string"
              ]
            }
          }
        }
      }
    },
    "instance.type.deployment": {
      "title": "Deployment controller",
      "properties": {
        "type": {
          "const": "deployment"
        },
        "horizontalPodAutoscaler": {
          "$ref": "#/$defs/horizontalPodAutoscaler"
        }
      }
    },
    "instance.type.statefulset": {
      "title": "StatefulSet controller",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "statefulset"
        },
        "horizontalPodAutoscaler": {
          "$ref": "#/$defs/horizontalPodAutoscaler"
        },
        "statefulset": {
          "description": "StatefulSet-specific options.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "podManagementPolicy": {
              "description": "Pod management policy. Valid values are Parallel and OrderedReady (default).",
              "type": "string"
            },
            "persistentVolumeClaimRetentionPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "whenDeleted": {
                  "type": "string",
                  "enum": [
                    "Delete",
                    "Retain"
                  ],
                  "default": "Retain"
                },
                "whenScaled": {
                  "type": "string",
                  "enum": [
                    "Delete",
                    "Retain"
                  ],
                  "default": "Retain"
                }
              }
            },
            "serviceName": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "identifier": {
                      "type": "string"
                    }
                  }
                }
              ]
            },
            "startOrdinal": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "volumeClaimTemplates": {
              "description": "Volume claim templates for the StatefulSet. Each entry creates a PVC per pod.",
              "type": "array",
              "items": {
                "$ref": "#/$defs/statefulset.volumeClaimTemplate"
              }
            }
          }
        }
      }
    },
    "instance.type.daemonset": {
      "title": "DaemonSet controller",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "daemonset"
        }
      }
    },
    "instance.type.cronjob": {
      "title": "CronJob controller",
      "required": [
        "type",
        "cronjob"
      ],
      "properties": {
        "type": {
          "const": "cronjob"
        },
        "cronjob": {
          "description": "CronJob-specific options.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schedule"
          ],
          "properties": {
            "backoffLimit": {
              "description": "Number of retries before marking the job as failed.",
              "type": "integer",
              "default": 6
            },
            "concurrencyPolicy": {
              "description": "Valid values are Allow, Forbid or Replace.",
              "type": "string",
              "default": "Forbid"
            },
            "failedJobsHistory": {
              "description": "Number of failed finished jobs to retain.",
              "type": "integer",
              "default": 1
            },
            "parallelism": {
              "description": "Maximum number of pods running at any given time.",
              "type": "integer"
            },
            "schedule": {
              "description": "Cron schedule expression (e.g. '*/20 * * * *').",
              "type": "string"
            },
            "startingDeadlineSeconds": {
              "description": "Deadline in seconds for starting the job if it misses its scheduled time.",
              "type": "integer",
              "default": 30
            },
            "successfulJobsHistory": {
              "description": "Number of successful finished jobs to retain.",
              "type": "integer",
              "default": 1
            },
            "suspend": {
              "description": "Suspend execution of the CronJob. See https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/#schedule-suspend for details.",
              "type": "boolean",
              "default": false
            },
            "timeZone": {
              "description": "IANA time zone name for CronJob schedule (e.g. 'Etc/UTC'). Only works in Kubernetes >= 1.27.",
              "type": "string"
            },
            "activeDeadlineSeconds": {
              "type": "integer"
            },
            "ttlSecondsAfterFinished": {
              "description": "Time in seconds after which a finished Job is eligible for automatic deletion.",
              "type": "integer"
            }
          }
        }
      }
    },
    "instance.type.job": {
      "title": "Job controller",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "job"
        },
        "job": {
          "description": "Job-specific options.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "backoffLimit": {
              "description": "Number of retries before marking the job as failed.",
              "type": "integer",
              "default": 6
            },
            "completions": {
              "description": "Number of completions needed before the job is done."
            },
            "completionMode": {
              "description": "Completion mode for the Job."
            },
            "parallelism": {
              "description": "Maximum number of pods running at any given time.",
              "type": "integer"
            },
            "suspend": {
              "description": "Suspend execution of the Job. See https://kubernetes.io/docs/concepts/workloads/controllers/job/#suspending-a-job for details.",
              "type": "boolean",
              "default": false
            },
            "activeDeadlineSeconds": {
              "type": "integer"
            },
            "ttlSecondsAfterFinished": {
              "description": "Time in seconds after which a finished Job is eligible for automatic deletion.",
              "type": "integer"
            }
          }
        }
      }
    },
    "horizontalPodAutoscaler": {
      "description": "HorizontalPodAutoscaler configuration for this controller. Only supported for deployment and statefulset types. See https://kubernetes.io/docs/tasks/run-application/horizontal-pod-autoscale/ for details.",
      "type": "object",
      "required": [
        "maxReplicas"
      ],
      "properties": {
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "minReplicas": {
          "description": "Minimum number of replicas. Set to 0 to enable scale-to-zero when the HPAScaleToZero feature gate is enabled.",
          "type": [
            "integer",
            "null"
          ]
        },
        "maxReplicas": {
          "description": "Maximum number of replicas.",
          "type": "integer",
          "minimum": 1
        },
        "metrics": {
          "description": "Metrics to use for scaling. Passed through directly to the autoscaling/v2 HPA spec.",
          "type": "array"
        },
        "behavior": {
          "description": "Scaling behavior configuration. Passed through directly to the autoscaling/v2 HPA spec.",
          "type": "object"
        }
      }
    },
    "statefulset.volumeClaimTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "size"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "accessMode": {
          "type": "string"
        },
        "advancedMounts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "persistence.json#/$defs/mountPathCollection"
          }
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "dataSource": {
          "$ref": "persistence.json#/$defs/dataSourceReference"
        },
        "dataSourceRef": {
          "$ref": "persistence.json#/$defs/dataSourceReference"
        },
        "globalMounts": {
          "$ref": "persistence.json#/$defs/globalMounts"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "name": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "storageClass": {
          "type": "string"
        }
      }
    }
  }
}
