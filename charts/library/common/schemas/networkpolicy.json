{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/networkpolicy.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the NetworkPolicy.",
          "type": "boolean",
          "default": true
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "controller": {
          "description": "Controller this NetworkPolicy should target.",
          "type": "string"
        },
        "extraSelectorLabels": {
          "description": "Additional match labels to add to the pod selector. These are merged with labels derived from the controller identifier.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "podSelector": {
          "description": "Custom podSelector for the NetworkPolicy. Takes precedence over targeting a controller via the controller identifier."
        },
        "policyTypes": {
          "description": "Policy types for the NetworkPolicy.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "Egress",
              "Ingress"
            ]
          }
        },
        "rules": {
          "description": "Ingress and egress rules for the NetworkPolicy. See https://kubernetes.io/docs/concepts/services-networking/network-policies/#networkpolicy-resource for details. Use `- {}` as an item to allow all traffic for that direction.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ingress": {
              "description": "Ingress rules for this networkPolicy. An entry of `{}` allows all ingress traffic.",
              "type": "array",
              "items": {
                "$ref": "k8s-api.json#/$defs/networking.v1.NetworkPolicyIngressRule"
              }
            },
            "egress": {
              "description": "Egress rules for this networkPolicy. An entry of `{}` allows all egress traffic.",
              "type": "array",
              "items": {
                "$ref": "k8s-api.json#/$defs/networking.v1.NetworkPolicyEgressRule"
              }
            }
          }
        }
      },
      "dependentSchemas": {
        "podSelector": {
          "not": {
            "required": [
              "controller"
            ]
          }
        },
        "controller": {
          "not": {
            "required": [
              "podSelector"
            ]
          }
        }
      },
      "required": [
        "policyTypes",
        "rules"
      ]
    }
  }
}
