{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/schemas/serviceAccount.json",
  "$defs": {
    "instance": {
      "type": "object",
      "allOf": [
        {
          "$ref": "definitions.json#/$defs/resourceIdentifier"
        }
      ],
      "unevaluatedProperties": false,
      "properties": {
        "enabled": {
          "description": "Set to false to disable the ServiceAccount.",
          "type": "boolean",
          "default": true
        },
        "annotations": {
          "$ref": "definitions.json#/$defs/annotations"
        },
        "labels": {
          "$ref": "definitions.json#/$defs/labels"
        },
        "staticToken": {
          "description": "Set to true to create a long-lived static token for the ServiceAccount.",
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
